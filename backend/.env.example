APP_NAME=AgentFlow AI
APP_ENV=development
# 复制本文件为 .env 后填入真实密钥；切勿把真实密钥提交进仓库
OPENAI_API_KEY=sk-your-api-key-here
# DeepSeek 示例；用 OpenAI 官方时改为 https://api.openai.com/v1
OPENAI_BASE_URL=https://api.deepseek.com
# 与网关/厂商一致即可，例如 deepseek-chat、deepseek-reasoner
OPENAI_MODEL=deepseek-chat
LLM_REQUEST_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.5
SQLITE_DATABASE_PATH=./data/agentflow_sessions.sqlite3
FRONTEND_ORIGIN=http://localhost:3000

# Optional: DEBUG prints each SSE event type, provider message roles, tool argument previews (see README)
# LOG_LEVEL=DEBUG
